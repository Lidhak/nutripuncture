{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nutripuncture Desk",
  "version": "0.1.0",
  "identifier": "fr.local.nutripuncture-desk",
  "build": {
    "beforeDevCommand": "cd ../frontend && npm run dev -- --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "cd ../frontend && npm run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nutripuncture Desk",
        "width": 1360,
        "height": 860,
        "minWidth": 1100,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
